page {
  min-height: 100%;
  background:
    radial-gradient(circle at top, rgba(122, 92, 255, 0.24), transparent 32%),
    linear-gradient(180deg, #0d0d0d 0%, #131722 52%, #0d0d0d 100%);
  color: #f4f4f4;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
picker,
textarea {
  box-sizing: border-box;
}

.page-shell {
  padding: 32rpx 28rpx 48rpx;
}

.hero {
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(24rpx);
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.25);
}

.hero-kicker {
  color: #ff9cc0;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 52rpx;
  line-height: 1.18;
  font-weight: 600;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: #c9cfdf;
  font-size: 26rpx;
  line-height: 1.6;
}

.hero-stage {
  position: relative;
  height: 220rpx;
  margin-top: 26rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at center, rgba(255, 77, 141, 0.15), transparent 26%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
}

.crowd-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 88rpx;
  height: 88rpx;
  margin-left: -44rpx;
  margin-top: -44rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7a5cff 0%, #ff4d8d 100%);
  box-shadow: 0 0 40rpx rgba(122, 92, 255, 0.45);
}

.crowd-member {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  opacity: 0.9;
  animation: gather 3.6s ease-in-out infinite;
}

.crowd-glyph {
  color: #11131a;
  font-size: 22rpx;
  font-weight: 700;
}

.member-a {
  left: 18rpx;
  top: 22rpx;
  animation-delay: 0s;
}

.member-b {
  right: 42rpx;
  top: 16rpx;
  animation-delay: 0.4s;
}

.member-c {
  left: 54rpx;
  bottom: 22rpx;
  animation-delay: 0.8s;
}

.member-d {
  right: 18rpx;
  bottom: 30rpx;
  animation-delay: 1.2s;
}

.member-e {
  left: 150rpx;
  top: 82rpx;
  animation-delay: 1.6s;
}

.member-f {
  right: 150rpx;
  bottom: 76rpx;
  animation-delay: 2s;
}

@keyframes gather {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(0.92);
    opacity: 0.42;
  }

  50% {
    transform: translate3d(120rpx, 46rpx, 0) scale(1.08);
    opacity: 1;
  }
}

.section {
  margin-top: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f3f3f3;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a8a8a;
}

.glass-card {
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.045);
  backdrop-filter: blur(24rpx);
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #cfd2da;
  font-size: 22rpx;
}

.pill.active {
  background: rgba(122, 92, 255, 0.24);
  color: #ffffff;
  border: 1rpx solid rgba(122, 92, 255, 0.65);
}

.primary-btn {
  height: 88rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(135deg, #7a5cff 0%, #ff4d8d 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-btn[disabled] {
  opacity: 0.45;
  color: rgba(255, 255, 255, 0.85);
}

.secondary-btn {
  height: 84rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);
  color: #f3f3f3;
  font-size: 28rpx;
}

.field {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #dfe3ee;
  font-size: 24rpx;
}

.field-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 28rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.metric-card {
  padding: 24rpx;
}

.metric-value {
  font-size: 42rpx;
  font-weight: 600;
}

.metric-label {
  margin-top: 8rpx;
  color: #9ca3b7;
  font-size: 22rpx;
}

.empty-state {
  padding: 40rpx 32rpx;
  text-align: center;
  color: #9aa1b4;
}

.avatar-row {
  display: flex;
  align-items: center;
}

.avatar-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  margin-left: -12rpx;
  border: 4rpx solid rgba(13, 13, 13, 0.9);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
}

.avatar-chip:first-child {
  margin-left: 0;
}

.avatar-more {
  margin-left: 10rpx;
  color: #9da4b8;
  font-size: 22rpx;
}

.feature-strip {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.feature-card {
  padding: 24rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
}

.feature-desc {
  margin-top: 10rpx;
  color: #b2b8c8;
  font-size: 23rpx;
  line-height: 1.6;
}
