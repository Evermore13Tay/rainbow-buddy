.event-card {
  margin-top: 24rpx;
  padding: 26rpx;
}

.event-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.event-kicker {
  color: #ff9cc0;
  font-size: 22rpx;
}

.event-title {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 600;
  line-height: 1.24;
}

.event-date {
  color: #d8deed;
  font-size: 24rpx;
}

.event-meta {
  margin-top: 12rpx;
  color: #aab0bf;
  font-size: 24rpx;
}

.event-discount {
  margin-top: 14rpx;
  color: #ffd7a8;
  font-size: 23rpx;
}

.event-tags {
  margin-top: 18rpx;
}

.event-foot {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 22rpx;
  gap: 20rpx;
}

.event-people {
  margin-top: 10rpx;
  color: #d7dced;
  font-size: 24rpx;
}

.event-cta {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(122, 92, 255, 0.18);
  color: #ffffff;
  font-size: 24rpx;
}
