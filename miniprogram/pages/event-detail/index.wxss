.detail-card {
  margin-top: 24rpx;
  padding: 26rpx;
}

.created-banner {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  color: #ffd7a8;
  font-size: 24rpx;
  line-height: 1.7;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.detail-row:last-child {
  border-bottom: 0;
}

.detail-label {
  color: #9aa1b4;
  font-size: 24rpx;
}

.detail-value {
  color: #f4f4f4;
  font-size: 24rpx;
  text-align: right;
}

.rules,
.group-hint,
.share-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.rule-item {
  margin-top: 12rpx;
  color: #d7dced;
  font-size: 24rpx;
  line-height: 1.7;
}

.rule-item:first-child {
  margin-top: 0;
}

.boarding-copy {
  margin-top: 16rpx;
  color: #d7dced;
  font-size: 24rpx;
}

.share-copy {
  color: #d7dced;
  font-size: 24rpx;
  line-height: 1.7;
}

.share-path {
  margin-top: 18rpx;
  word-break: break-all;
  color: #ffcf9c;
  font-size: 22rpx;
}

.share-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.share-btn {
  flex: 1;
}

.cta-bar {
  margin-top: 34rpx;
}
