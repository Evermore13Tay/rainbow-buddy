<view class="page-shell game-page">
  <view class="game-bg game-bg-a"></view>
  <view class="game-bg game-bg-b"></view>

  <view class="hero game-hero">
    <view class="hero-meta">
      <text class="hero-kicker">DRINKING GAME</text>
      <text class="hero-count">剩余 {{remainingCount}} / 16</text>
    </view>
    <view class="hero-title">WHO DRINKS?</view>
    <view class="hero-subtitle">
      16 型 MBTI 老头里只有 1 个是真的。点错会消失，点中就被酒杯锁定。
    </view>
    <view class="game-rule-pill">
      <view class="rule-item">
        <text class="rule-label">点错</text>
        <text class="rule-value">爆炸 / 献花</text>
      </view>
      <view class="rule-divider"></view>
      <view class="rule-item">
        <text class="rule-label">点中</text>
        <text class="rule-value">全场开喝</text>
      </view>
    </view>
  </view>

  <view class="game-toolbar">
    <text>隐藏 1 个真老头</text>
    <text>点中者喝酒</text>
  </view>

  <view class="game-grid">
    <block wx:for="{{cells}}" wx:key="id">
      <view
        class="game-cell glass-card {{item.groupClass}} {{item.isRemoved ? 'removed' : ''}} {{item.isShaking ? 'shaking' : ''}} {{item.isClicked && item.isReal ? 'hit-real' : ''}}"
        data-index="{{index}}"
        bindtap="handleCellTap"
      >
        <view class="cell-number">{{item.type}}</view>
        <view class="meme-burst"></view>
        <view class="stage-glow"></view>
        <image class="mbti-icon" src="{{item.imageSrc}}" mode="aspectFit"></image>
        <view class="reaction-boom" wx:if="{{item.reaction === 'boom'}}">
          <view class="boom-core"></view>
          <view class="boom-ring"></view>
          <view class="boom-spark spark-a"></view>
          <view class="boom-spark spark-b"></view>
          <view class="boom-spark spark-c"></view>
        </view>
        <view class="reaction-flower" wx:if="{{item.reaction === 'flower'}}" style="animation-delay: {{item.flowerDelay}};">
          <view class="petal petal-a"></view>
          <view class="petal petal-b"></view>
          <view class="petal petal-c"></view>
          <view class="petal petal-d"></view>
          <view class="flower-core"></view>
          <view class="flower-stem"></view>
        </view>
        <view class="reaction-cheers" wx:if="{{item.reaction === 'cheers'}}">
          <view class="mini-cup left"></view>
          <view class="mini-cup right"></view>
        </view>
      </view>
    </block>
  </view>

  <view class="panorama-mask" wx:if="{{hitPanorama}}">
    <view class="panorama-flash"></view>
    <view class="cup-flight cup-left">
      <view class="cup-bowl"></view>
      <view class="cup-stem"></view>
    </view>
    <view class="cup-flight cup-right">
      <view class="cup-bowl"></view>
      <view class="cup-stem"></view>
    </view>
    <view class="collision-burst">
      <view class="burst-ring"></view>
      <view class="burst-star star-a"></view>
      <view class="burst-star star-b"></view>
      <view class="burst-star star-c"></view>
    </view>
  </view>

  <view class="result-mask" wx:if="{{showResult}}" catchtap="handleOverlayTap">
    <view class="result-panel glass-card">
      <view class="result-title">{{resultText}}</view>
      <view class="result-desc">点击任意位置，重新一局</view>
    </view>
  </view>
</view>
