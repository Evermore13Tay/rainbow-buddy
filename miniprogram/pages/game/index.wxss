.game-page {
  position: relative;
}

.game-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
  margin-top: 28rpx;
}

.game-cell {
  position: relative;
  height: 196rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.16), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
  transition: transform 0.22s ease, opacity 0.22s ease;
}

.game-cell.removed {
  opacity: 0;
  transform: scale(0.82);
  pointer-events: none;
}

.game-cell.shaking {
  animation: old-man-hit 0.22s ease;
}

.game-cell.hit-real {
  box-shadow: 0 0 0 2rpx rgba(255, 77, 141, 0.45), 0 12rpx 40rpx rgba(255, 77, 141, 0.2);
}

.stage-glow {
  position: absolute;
  left: 50%;
  bottom: 16rpx;
  width: 84rpx;
  height: 18rpx;
  margin-left: -42rpx;
  border-radius: 999rpx;
  background: rgba(255, 77, 141, 0.2);
  filter: blur(8rpx);
}

.old-man-figure {
  position: absolute;
  inset: 0;
  transform: translateZ(0);
}

.old-man-hair {
  position: absolute;
  left: 50%;
  top: 22rpx;
  width: 58rpx;
  height: 24rpx;
  margin-left: -29rpx;
  border-radius: 30rpx 30rpx 16rpx 16rpx;
  background: linear-gradient(180deg, #f1f5ff 0%, #b7bfcd 100%);
}

.old-man-head {
  position: absolute;
  left: 50%;
  top: 30rpx;
  width: 52rpx;
  height: 56rpx;
  margin-left: -26rpx;
  border-radius: 24rpx 24rpx 22rpx 22rpx;
  background: linear-gradient(180deg, #f7ead9 0%, #dcb68f 78%);
  box-shadow: inset 0 -8rpx 12rpx rgba(123, 78, 43, 0.14);
}

.old-man-jaw {
  position: absolute;
  left: 50%;
  top: 68rpx;
  width: 34rpx;
  height: 14rpx;
  margin-left: -17rpx;
  border-radius: 0 0 18rpx 18rpx;
  background: rgba(255, 255, 255, 0.82);
}

.old-man-glasses {
  position: absolute;
  left: 50%;
  top: 50rpx;
  width: 52rpx;
  height: 12rpx;
  margin-left: -26rpx;
  border-top: 4rpx solid rgba(39, 50, 69, 0.85);
}

.old-man-glasses::before,
.old-man-glasses::after {
  content: '';
  position: absolute;
  top: -10rpx;
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid rgba(39, 50, 69, 0.85);
  border-radius: 999rpx;
}

.old-man-glasses::before {
  left: 4rpx;
}

.old-man-glasses::after {
  right: 4rpx;
}

.old-man-body {
  position: absolute;
  left: 50%;
  top: 86rpx;
  width: 74rpx;
  height: 76rpx;
  margin-left: -37rpx;
  border-radius: 28rpx 28rpx 18rpx 18rpx;
  background: linear-gradient(180deg, #7a5cff 0%, #3f2f82 100%);
  box-shadow: inset -12rpx -12rpx 18rpx rgba(12, 9, 31, 0.26);
}

.old-man-jacket-shine {
  position: absolute;
  left: 50%;
  top: 90rpx;
  width: 26rpx;
  height: 60rpx;
  margin-left: -20rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.38), rgba(255, 255, 255, 0));
  transform: rotate(10deg);
}

.old-man-leg {
  position: absolute;
  top: 146rpx;
  width: 12rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #272f3f 0%, #151822 100%);
}

.old-man-leg.left {
  left: 50%;
  margin-left: -22rpx;
}

.old-man-leg.right {
  left: 50%;
  margin-left: 10rpx;
}

.old-man-cane {
  position: absolute;
  left: 50%;
  top: 94rpx;
  width: 8rpx;
  height: 78rpx;
  margin-left: 34rpx;
  border-radius: 999rpx;
  background: #f6bd60;
}

.old-man-cane::before {
  content: '';
  position: absolute;
  left: -8rpx;
  top: -6rpx;
  width: 18rpx;
  height: 10rpx;
  border: 4rpx solid #f6bd60;
  border-bottom: 0;
  border-radius: 14rpx 14rpx 0 0;
}

.reaction-boom,
.reaction-flower,
.reaction-cheers {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.reaction-boom {
  animation: reaction-fade 0.42s ease forwards;
}

.boom-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 40rpx;
  height: 40rpx;
  margin-left: -20rpx;
  margin-top: -20rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, #fff2b7 0%, #ff8c42 60%, rgba(255, 77, 141, 0.1) 100%);
}

.boom-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 96rpx;
  height: 96rpx;
  margin-left: -48rpx;
  margin-top: -48rpx;
  border: 6rpx solid rgba(255, 180, 88, 0.65);
  border-radius: 999rpx;
  animation: boom-ring 0.42s ease forwards;
}

.boom-spark {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10rpx;
  height: 36rpx;
  margin-left: -5rpx;
  margin-top: -18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fff0a5 0%, #ff4d8d 100%);
}

.spark-a {
  transform: rotate(15deg) translateY(-50rpx);
}

.spark-b {
  transform: rotate(75deg) translateY(-50rpx);
}

.spark-c {
  transform: rotate(135deg) translateY(-50rpx);
}

.reaction-flower {
  animation: reaction-fade 0.6s ease forwards;
}

.petal {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 30rpx;
  margin-left: -11rpx;
  margin-top: -48rpx;
  border-radius: 18rpx 18rpx 4rpx 18rpx;
  background: linear-gradient(180deg, #ffaccd 0%, #ff4d8d 100%);
}

.petal-a {
  transform: rotate(0deg) translateY(-6rpx);
}

.petal-b {
  transform: rotate(90deg) translateY(-6rpx);
}

.petal-c {
  transform: rotate(180deg) translateY(-6rpx);
}

.petal-d {
  transform: rotate(270deg) translateY(-6rpx);
}

.flower-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20rpx;
  height: 20rpx;
  margin-left: -10rpx;
  margin-top: -10rpx;
  border-radius: 999rpx;
  background: #ffd166;
}

.flower-stem {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 8rpx;
  height: 70rpx;
  margin-left: -4rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #4ade80 0%, #166534 100%);
}

.reaction-cheers {
  animation: reaction-fade 0.9s ease forwards;
}

.mini-cup {
  position: absolute;
  top: 52rpx;
  width: 30rpx;
  height: 44rpx;
  border-radius: 8rpx 8rpx 12rpx 12rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.45) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.45);
}

.mini-cup::after {
  content: '';
  position: absolute;
  left: 6rpx;
  right: 6rpx;
  bottom: 6rpx;
  height: 18rpx;
  border-radius: 0 0 10rpx 10rpx;
  background: linear-gradient(180deg, #ffd166 0%, #f97316 100%);
}

.mini-cup.left {
  left: 30rpx;
  transform: rotate(-18deg);
}

.mini-cup.right {
  right: 30rpx;
  transform: rotate(18deg);
}

.panorama-mask {
  position: fixed;
  inset: 0;
  z-index: 9;
  overflow: hidden;
  pointer-events: none;
}

.panorama-flash {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(255, 214, 102, 0.28), rgba(255, 77, 141, 0.16), transparent 65%);
  animation: panorama-flash 0.9s ease forwards;
}

.cup-flight {
  position: absolute;
  top: 44%;
  width: 120rpx;
  height: 180rpx;
  animation-duration: 0.9s;
  animation-fill-mode: forwards;
  animation-timing-function: cubic-bezier(0.2, 0.75, 0.2, 1);
}

.cup-left {
  left: -120rpx;
  animation-name: cup-left-fly;
}

.cup-right {
  right: -120rpx;
  animation-name: cup-right-fly;
}

.cup-bowl {
  position: absolute;
  left: 50%;
  top: 0;
  width: 86rpx;
  height: 92rpx;
  margin-left: -43rpx;
  border-radius: 18rpx 18rpx 28rpx 28rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,255,255,0.28));
  border: 4rpx solid rgba(255,255,255,0.48);
}

.cup-bowl::after {
  content: '';
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  height: 34rpx;
  border-radius: 0 0 20rpx 20rpx;
  background: linear-gradient(180deg, #ffd166 0%, #f97316 100%);
}

.cup-stem {
  position: absolute;
  left: 50%;
  top: 92rpx;
  width: 12rpx;
  height: 62rpx;
  margin-left: -6rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.68);
}

.cup-stem::after {
  content: '';
  position: absolute;
  left: -24rpx;
  bottom: -12rpx;
  width: 60rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.48);
}

.collision-burst {
  position: absolute;
  left: 50%;
  top: 44%;
  width: 180rpx;
  height: 180rpx;
  margin-left: -90rpx;
  margin-top: -90rpx;
  animation: collision-pop 0.9s ease forwards;
}

.burst-ring {
  position: absolute;
  inset: 24rpx;
  border: 8rpx solid rgba(255, 215, 140, 0.7);
  border-radius: 999rpx;
}

.burst-star {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 14rpx;
  height: 68rpx;
  margin-left: -7rpx;
  margin-top: -34rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fff6b7 0%, #ff4d8d 100%);
}

.star-a {
  transform: rotate(0deg);
}

.star-b {
  transform: rotate(60deg);
}

.star-c {
  transform: rotate(120deg);
}

.result-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(7, 8, 12, 0.72);
  z-index: 10;
}

.result-panel {
  width: 100%;
  max-width: 620rpx;
  padding: 42rpx 32rpx;
  text-align: center;
}

.result-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
}

.result-desc {
  margin-top: 18rpx;
  color: #cad0df;
  font-size: 26rpx;
}

@keyframes old-man-hit {
  0% {
    transform: scale(1);
  }

  35% {
    transform: scale(0.92) rotate(-3deg);
  }

  70% {
    transform: scale(1.04) rotate(3deg);
  }

  100% {
    transform: scale(1);
  }
}

@keyframes reaction-fade {
  0% {
    opacity: 0;
    transform: scale(0.82);
  }

  20%,
  70% {
    opacity: 1;
    transform: scale(1);
  }

  100% {
    opacity: 0;
    transform: scale(1.12);
  }
}

@keyframes boom-ring {
  0% {
    opacity: 0.9;
    transform: scale(0.4);
  }

  100% {
    opacity: 0;
    transform: scale(1.3);
  }
}

@keyframes panorama-flash {
  0% {
    opacity: 0;
  }

  15%,
  70% {
    opacity: 1;
  }

  100% {
    opacity: 0;
  }
}

@keyframes cup-left-fly {
  0% {
    transform: translate3d(0, 40rpx, 0) rotate(-28deg) scale(0.9);
  }

  75% {
    transform: translate3d(380rpx, -20rpx, 0) rotate(8deg) scale(1.08);
  }

  100% {
    transform: translate3d(430rpx, -10rpx, 0) rotate(14deg) scale(1.05);
  }
}

@keyframes cup-right-fly {
  0% {
    transform: translate3d(0, 50rpx, 0) rotate(28deg) scale(0.9);
  }

  75% {
    transform: translate3d(-380rpx, -20rpx, 0) rotate(-8deg) scale(1.08);
  }

  100% {
    transform: translate3d(-430rpx, -10rpx, 0) rotate(-14deg) scale(1.05);
  }
}

@keyframes collision-pop {
  0% {
    opacity: 0;
    transform: scale(0.25);
  }

  45%,
  80% {
    opacity: 1;
    transform: scale(1);
  }

  100% {
    opacity: 0;
    transform: scale(1.26);
  }
}

.game-page {
  min-height: 100vh;
  overflow: hidden;
  padding-bottom: 64rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(122, 92, 255, 0.42), transparent 34%),
    radial-gradient(circle at 88% 12%, rgba(255, 77, 141, 0.36), transparent 30%),
    linear-gradient(180deg, #070711 0%, #141020 48%, #070710 100%);
}

.game-bg {
  position: fixed;
  z-index: 0;
  pointer-events: none;
  border-radius: 999rpx;
  filter: blur(20rpx);
}

.game-bg-a {
  top: 72rpx;
  left: -80rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(122, 92, 255, 0.28);
}

.game-bg-b {
  top: 210rpx;
  right: -96rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 77, 141, 0.22);
}

.game-hero,
.game-toolbar,
.game-grid {
  position: relative;
  z-index: 1;
}

.game-hero {
  padding: 34rpx 30rpx 28rpx;
  border-color: rgba(255, 255, 255, 0.13);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 12% 8%, rgba(255, 255, 255, 0.2), transparent 28%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.035));
  box-shadow:
    0 24rpx 80rpx rgba(0, 0, 0, 0.34),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
}

.hero-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.game-hero .hero-kicker {
  color: #ff9ccf;
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 5rpx;
  text-shadow: 0 0 18rpx rgba(255, 77, 141, 0.48);
}

.hero-count {
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.08);
}

.game-hero .hero-title {
  margin-top: 26rpx;
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.game-hero .hero-subtitle {
  max-width: 620rpx;
  margin-top: 18rpx;
  color: #d8dcef;
  font-size: 25rpx;
  line-height: 1.58;
}

.game-rule-pill {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 26rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 77, 141, 0.22), rgba(122, 92, 255, 0.2));
}

.rule-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.rule-label {
  color: rgba(255, 255, 255, 0.56);
  font-size: 20rpx;
}

.rule-value {
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
}

.rule-divider {
  width: 1rpx;
  height: 46rpx;
  margin: 0 22rpx;
  background: rgba(255, 255, 255, 0.16);
}

.game-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  color: #aeb5c9;
  font-size: 23rpx;
}

.game-grid {
  gap: 16rpx;
  margin-top: 18rpx;
}

.game-cell {
  height: 202rpx;
  border-color: rgba(255, 255, 255, 0.12);
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 50% 12%, rgba(255, 255, 255, 0.2), transparent 32%),
    radial-gradient(circle at 50% 88%, rgba(255, 77, 141, 0.16), transparent 38%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.105), rgba(255, 255, 255, 0.025));
  box-shadow:
    0 16rpx 34rpx rgba(0, 0, 0, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.16);
}

.game-cell::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.16), transparent 34%);
  pointer-events: none;
}

.game-cell:active {
  transform: scale(0.96);
}

.game-cell.hit-real {
  border-color: rgba(255, 77, 141, 0.72);
  box-shadow:
    0 0 0 2rpx rgba(255, 77, 141, 0.45),
    0 18rpx 54rpx rgba(255, 77, 141, 0.32),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

.cell-number,
.cell-tap-hint {
  position: absolute;
  z-index: 2;
  color: rgba(255, 255, 255, 0.5);
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.cell-number {
  left: 14rpx;
  top: 12rpx;
}

.cell-tap-hint {
  right: 14rpx;
  bottom: 12rpx;
  color: rgba(255, 156, 207, 0.62);
}

.stage-glow {
  bottom: 18rpx;
  width: 94rpx;
  height: 22rpx;
  margin-left: -47rpx;
  background: rgba(255, 77, 141, 0.28);
  filter: blur(10rpx);
}

.old-man-hair {
  top: 24rpx;
  box-shadow: 0 0 18rpx rgba(255, 255, 255, 0.18);
}

.old-man-body {
  background: linear-gradient(180deg, #8d6bff 0%, #3f2f82 100%);
  box-shadow:
    inset -12rpx -12rpx 18rpx rgba(12, 9, 31, 0.28),
    0 0 24rpx rgba(122, 92, 255, 0.22);
}

.old-man-cane {
  background: linear-gradient(180deg, #ffe082 0%, #f6bd60 100%);
  box-shadow: 0 0 16rpx rgba(246, 189, 96, 0.24);
}

.old-man-cane::before {
  border-color: #ffe082;
}

.boom-core {
  box-shadow: 0 0 36rpx rgba(255, 140, 66, 0.6);
}

.mini-cup {
  box-shadow: 0 0 24rpx rgba(255, 255, 255, 0.28);
}

.panorama-flash {
  background:
    radial-gradient(circle at center, rgba(255, 214, 102, 0.36), rgba(255, 77, 141, 0.22), transparent 64%),
    rgba(7, 8, 12, 0.18);
}

.result-mask {
  background:
    radial-gradient(circle at center, rgba(255, 77, 141, 0.24), transparent 42%),
    rgba(7, 8, 12, 0.76);
}

.result-panel {
  border-color: rgba(255, 255, 255, 0.16);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 77, 141, 0.22), transparent 46%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.13), rgba(255, 255, 255, 0.05));
  box-shadow:
    0 28rpx 90rpx rgba(0, 0, 0, 0.42),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
}

.result-title {
  font-size: 50rpx;
  line-height: 1.18;
  text-shadow: 0 0 28rpx rgba(255, 77, 141, 0.46);
}

.result-desc {
  color: #dce1f3;
}

.game-page .game-grid {
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.game-page .game-cell {
  height: 204rpx;
  border: 0;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 50% 14%, rgba(255, 255, 255, 0.34), transparent 38%),
    linear-gradient(180deg, rgba(122, 92, 255, 0.48), rgba(122, 92, 255, 0.18));
  backdrop-filter: blur(18rpx);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.2),
    0 10rpx 22rpx rgba(0, 0, 0, 0.2);
}

.game-page .game-cell::after {
  display: none;
}

.game-page .game-cell.group-purple {
  background:
    radial-gradient(circle at 50% 14%, rgba(255, 255, 255, 0.34), transparent 38%),
    linear-gradient(180deg, rgba(122, 92, 255, 0.48), rgba(122, 92, 255, 0.18));
}

.game-page .game-cell.group-green {
  background:
    radial-gradient(circle at 50% 14%, rgba(255, 255, 255, 0.34), transparent 38%),
    linear-gradient(180deg, rgba(34, 197, 94, 0.46), rgba(34, 197, 94, 0.18));
}

.game-page .game-cell.group-blue {
  background:
    radial-gradient(circle at 50% 14%, rgba(255, 255, 255, 0.34), transparent 38%),
    linear-gradient(180deg, rgba(96, 165, 250, 0.48), rgba(96, 165, 250, 0.18));
}

.game-page .game-cell.group-yellow {
  background:
    radial-gradient(circle at 50% 14%, rgba(255, 255, 255, 0.34), transparent 38%),
    linear-gradient(180deg, rgba(245, 158, 11, 0.48), rgba(245, 158, 11, 0.2));
}

.game-page .cell-number {
  left: 12rpx;
  top: 12rpx;
  z-index: 6;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  text-shadow: 0 3rpx 0 rgba(0, 0, 0, 0.5);
}

.game-page .stage-glow {
