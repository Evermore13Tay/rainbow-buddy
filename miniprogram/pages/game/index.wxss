.game-page {
  position: relative;
}

.game-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
  margin-top: 28rpx;
}

.game-cell {
  position: relative;
  height: 196rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.16), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
  transition: transform 0.22s ease, opacity 0.22s ease;
}

.game-cell.removed {
  opacity: 0;
  transform: scale(0.82);
  pointer-events: none;
}

.game-cell.shaking {
  animation: old-man-hit 0.22s ease;
}

.game-cell.hit-real {
  box-shadow: 0 0 0 2rpx rgba(255, 77, 141, 0.45), 0 12rpx 40rpx rgba(255, 77, 141, 0.2);
}

.stage-glow {
  position: absolute;
  left: 50%;
  bottom: 16rpx;
  width: 84rpx;
  height: 18rpx;
  margin-left: -42rpx;
  border-radius: 999rpx;
  background: rgba(255, 77, 141, 0.2);
  filter: blur(8rpx);
}

.old-man-figure {
  position: absolute;
  inset: 0;
  transform: translateZ(0);
}

.old-man-hair {
  position: absolute;
  left: 50%;
  top: 22rpx;
  width: 58rpx;
  height: 24rpx;
  margin-left: -29rpx;
  border-radius: 30rpx 30rpx 16rpx 16rpx;
  background: linear-gradient(180deg, #f1f5ff 0%, #b7bfcd 100%);
}

.old-man-head {
  position: absolute;
  left: 50%;
  top: 30rpx;
  width: 52rpx;
  height: 56rpx;
  margin-left: -26rpx;
  border-radius: 24rpx 24rpx 22rpx 22rpx;
  background: linear-gradient(180deg, #f7ead9 0%, #dcb68f 78%);
  box-shadow: inset 0 -8rpx 12rpx rgba(123, 78, 43, 0.14);
}

.old-man-jaw {
  position: absolute;
  left: 50%;
  top: 68rpx;
  width: 34rpx;
  height: 14rpx;
  margin-left: -17rpx;
  border-radius: 0 0 18rpx 18rpx;
  background: rgba(255, 255, 255, 0.82);
}

.old-man-glasses {
  position: absolute;
  left: 50%;
  top: 50rpx;
  width: 52rpx;
  height: 12rpx;
  margin-left: -26rpx;
  border-top: 4rpx solid rgba(39, 50, 69, 0.85);
}

.old-man-glasses::before,
.old-man-glasses::after {
  content: '';
  position: absolute;
  top: -10rpx;
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid rgba(39, 50, 69, 0.85);
  border-radius: 999rpx;
}

.old-man-glasses::before {
  left: 4rpx;
}

.old-man-glasses::after {
  right: 4rpx;
}

.old-man-body {
  position: absolute;
  left: 50%;
  top: 86rpx;
  width: 74rpx;
  height: 76rpx;
  margin-left: -37rpx;
  border-radius: 28rpx 28rpx 18rpx 18rpx;
  background: linear-gradient(180deg, #7a5cff 0%, #3f2f82 100%);
  box-shadow: inset -12rpx -12rpx 18rpx rgba(12, 9, 31, 0.26);
}

.old-man-jacket-shine {
  position: absolute;
  left: 50%;
  top: 90rpx;
  width: 26rpx;
  height: 60rpx;
  margin-left: -20rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.38), rgba(255, 255, 255, 0));
  transform: rotate(10deg);
}

.old-man-leg {
  position: absolute;
  top: 146rpx;
  width: 12rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #272f3f 0%, #151822 100%);
}

.old-man-leg.left {
  left: 50%;
  margin-left: -22rpx;
}

.old-man-leg.right {
  left: 50%;
  margin-left: 10rpx;
}

.old-man-cane {
  position: absolute;
  left: 50%;
  top: 94rpx;
  width: 8rpx;
  height: 78rpx;
  margin-left: 34rpx;
  border-radius: 999rpx;
  background: #f6bd60;
}

.old-man-cane::before {
  content: '';
  position: absolute;
  left: -8rpx;
  top: -6rpx;
  width: 18rpx;
  height: 10rpx;
  border: 4rpx solid #f6bd60;
  border-bottom: 0;
  border-radius: 14rpx 14rpx 0 0;
}

.reaction-boom,
.reaction-flower,
.reaction-cheers {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.reaction-boom {
  animation: reaction-fade 0.42s ease forwards;
}

.boom-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 40rpx;
  height: 40rpx;
  margin-left: -20rpx;
  margin-top: -20rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, #fff2b7 0%, #ff8c42 60%, rgba(255, 77, 141, 0.1) 100%);
}

.boom-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 96rpx;
  height: 96rpx;
  margin-left: -48rpx;
  margin-top: -48rpx;
  border: 6rpx solid rgba(255, 180, 88, 0.65);
  border-radius: 999rpx;
  animation: boom-ring 0.42s ease forwards;
}

.boom-spark {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 10rpx;
  height: 36rpx;
  margin-left: -5rpx;
  margin-top: -18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fff0a5 0%, #ff4d8d 100%);
}

.spark-a {
  transform: rotate(15deg) translateY(-50rpx);
}

.spark-b {
  transform: rotate(75deg) translateY(-50rpx);
}

.spark-c {
  transform: rotate(135deg) translateY(-50rpx);
}

.reaction-flower {
  animation: reaction-fade 0.6s ease forwards;
}

.petal {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 30rpx;
  margin-left: -11rpx;
  margin-top: -48rpx;
  border-radius: 18rpx 18rpx 4rpx 18rpx;
  background: linear-gradient(180deg, #ffaccd 0%, #ff4d8d 100%);
}

.petal-a {
  transform: rotate(0deg) translateY(-6rpx);
}

.petal-b {
  transform: rotate(90deg) translateY(-6rpx);
}

.petal-c {
  transform: rotate(180deg) translateY(-6rpx);
}

.petal-d {
  transform: rotate(270deg) translateY(-6rpx);
}

.flower-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20rpx;
  height: 20rpx;
  margin-left: -10rpx;
  margin-top: -10rpx;
  border-radius: 999rpx;
  background: #ffd166;
}

.flower-stem {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 8rpx;
  height: 70rpx;
  margin-left: -4rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #4ade80 0%, #166534 100%);
}

.reaction-cheers {
  animation: reaction-fade 0.9s ease forwards;
}

.mini-cup {
  position: absolute;
  top: 52rpx;
  width: 30rpx;
  height: 44rpx;
  border-radius: 8rpx 8rpx 12rpx 12rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.45) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.45);
}

.mini-cup::after {
  content: '';
  position: absolute;
  left: 6rpx;
  right: 6rpx;
  bottom: 6rpx;
  height: 18rpx;
  border-radius: 0 0 10rpx 10rpx;
  background: linear-gradient(180deg, #ffd166 0%, #f97316 100%);
}

.mini-cup.left {
  left: 30rpx;
  transform: rotate(-18deg);
}

.mini-cup.right {
  right: 30rpx;
  transform: rotate(18deg);
}

.panorama-mask {
  position: fixed;
  inset: 0;
  z-index: 9;
  overflow: hidden;
  pointer-events: none;
}

.panorama-flash {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(255, 214, 102, 0.28), rgba(255, 77, 141, 0.16), transparent 65%);
  animation: panorama-flash 0.9s ease forwards;
}

.cup-flight {
  position: absolute;
  top: 44%;
  width: 120rpx;
  height: 180rpx;
  animation-duration: 0.9s;
  animation-fill-mode: forwards;
  animation-timing-function: cubic-bezier(0.2, 0.75, 0.2, 1);
}

.cup-left {
  left: -120rpx;
  animation-name: cup-left-fly;
}

.cup-right {
  right: -120rpx;
  animation-name: cup-right-fly;
}

.cup-bowl {
  position: absolute;
  left: 50%;
  top: 0;
  width: 86rpx;
  height: 92rpx;
  margin-left: -43rpx;
  border-radius: 18rpx 18rpx 28rpx 28rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,255,255,0.28));
  border: 4rpx solid rgba(255,255,255,0.48);
}

.cup-bowl::after {
  content: '';
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  height: 34rpx;
  border-radius: 0 0 20rpx 20rpx;
  background: linear-gradient(180deg, #ffd166 0%, #f97316 100%);
}

.cup-stem {
  position: absolute;
  left: 50%;
  top: 92rpx;
  width: 12rpx;
  height: 62rpx;
  margin-left: -6rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.68);
}

.cup-stem::after {
  content: '';
  position: absolute;
  left: -24rpx;
  bottom: -12rpx;
  width: 60rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.48);
}

.collision-burst {
  position: absolute;
  left: 50%;
  top: 44%;
  width: 180rpx;
  height: 180rpx;
  margin-left: -90rpx;
  margin-top: -90rpx;
  animation: collision-pop 0.9s ease forwards;
}

.burst-ring {
  position: absolute;
  inset: 24rpx;
  border: 8rpx solid rgba(255, 215, 140, 0.7);
  border-radius: 999rpx;
}

.burst-star {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 14rpx;
  height: 68rpx;
  margin-left: -7rpx;
  margin-top: -34rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fff6b7 0%, #ff4d8d 100%);
}

.star-a {
  transform: rotate(0deg);
}

.star-b {
  transform: rotate(60deg);
}

.star-c {
  transform: rotate(120deg);
}

.result-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(7, 8, 12, 0.72);
  z-index: 10;
}

.result-panel {
  width: 100%;
  max-width: 620rpx;
  padding: 42rpx 32rpx;
  text-align: center;
}

.result-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
}

.result-desc {
  margin-top: 18rpx;
  color: #cad0df;
  font-size: 26rpx;
}

@keyframes old-man-hit {
  0% {
    transform: scale(1);
  }

  35% {
    transform: scale(0.92) rotate(-3deg);
  }

  70% {
    transform: scale(1.04) rotate(3deg);
  }

  100% {
    transform: scale(1);
  }
}

@keyframes reaction-fade {
  0% {
    opacity: 0;
    transform: scale(0.82);
  }

  20%,
  70% {
    opacity: 1;
    transform: scale(1);
  }

  100% {
    opacity: 0;
    transform: scale(1.12);
  }
}

@keyframes boom-ring {
  0% {
    opacity: 0.9;
    transform: scale(0.4);
  }

  100% {
    opacity: 0;
    transform: scale(1.3);
  }
}

@keyframes panorama-flash {
  0% {
    opacity: 0;
  }

  15%,
  70% {
    opacity: 1;
  }

  100% {
    opacity: 0;
  }
}

@keyframes cup-left-fly {
  0% {
    transform: translate3d(0, 40rpx, 0) rotate(-28deg) scale(0.9);
  }

  75% {
    transform: translate3d(380rpx, -20rpx, 0) rotate(8deg) scale(1.08);
  }

  100% {
    transform: translate3d(430rpx, -10rpx, 0) rotate(14deg) scale(1.05);
  }
}

@keyframes cup-right-fly {
  0% {
    transform: translate3d(0, 50rpx, 0) rotate(28deg) scale(0.9);
  }

  75% {
    transform: translate3d(-380rpx, -20rpx, 0) rotate(-8deg) scale(1.08);
  }

  100% {
    transform: translate3d(-430rpx, -10rpx, 0) rotate(-14deg) scale(1.05);
  }
}

@keyframes collision-pop {
  0% {
    opacity: 0;
    transform: scale(0.25);
  }

  45%,
  80% {
    opacity: 1;
    transform: scale(1);
  }

  100% {
    opacity: 0;
    transform: scale(1.26);
  }
}
