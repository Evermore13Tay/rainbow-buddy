.success-panel {
  padding: 38rpx 30rpx;
  text-align: center;
}

.success-mark {
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: rgba(122, 92, 255, 0.22);
  color: #ffffff;
  font-size: 42rpx;
  line-height: 92rpx;
}

.success-title {
  margin-top: 22rpx;
  font-size: 42rpx;
  font-weight: 600;
}

.success-desc {
  margin-top: 16rpx;
  color: #cfd4e4;
  font-size: 26rpx;
  line-height: 1.7;
}

.secondary-action {
  margin-top: 18rpx;
}
